{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Init Pico-PIO-USB dependency",
            "type": "process",
            "command": "python3",
            "args": [
                "tools/get_deps.py",
                "rp2040"
            ],
            "options": {
                "cwd": "${userHome}/.pico-sdk/sdk/2.2.0/lib/tinyusb"
            },
            "windows": {
                "command": "cmd.exe",
                "args": [
                    "/d",
                    "/c",
                    "if exist \"%USERPROFILE%\\.pico-sdk\\python\\3.12.1\\python.exe\" (\"%USERPROFILE%\\.pico-sdk\\python\\3.12.1\\python.exe\" tools\\get_deps.py rp2040) else (py -3 tools\\get_deps.py rp2040 || python tools\\get_deps.py rp2040)"
                ],
                "options": {
                    "cwd": "${env:USERPROFILE}/.pico-sdk/sdk/2.2.0/lib/tinyusb"
                }
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Configure Project",
            "type": "process",
            "command": "${userHome}/.pico-sdk/cmake/v3.31.5/bin/cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-G",
                "Ninja",
                "-DPICO_BOARD=pico2"
            ],
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/cmake/v3.31.5/bin/cmake.exe"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "dependsOn": "Init Pico-PIO-USB dependency"
        },
        {
            "label": "Compile Project",
            "type": "process",
            "command": "${userHome}/.pico-sdk/ninja/v1.12.1/ninja",
            "args": [
                "-C",
                "${workspaceFolder}/build"
            ],
            "dependsOn": "Configure Project",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$gcc",
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/ninja/v1.12.1/ninja.exe"
            }
        },
        {
            "label": "Run Project",
            "type": "process",
            "command": "${userHome}/.pico-sdk/picotool/2.2.0-a4/picotool/picotool",
            "args": [
                "load",
                "${workspaceFolder}/build/zuiki_usb_pio_host.uf2",
                "-fx"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/picotool/2.2.0-a4/picotool/picotool.exe"
            }
        },
        {
            "label": "Flash",
            "type": "process",
            "command": "${userHome}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            "args": [
                "-s",
                "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts",
                "-f",
                "interface/cmsis-dap.cfg",
                "-f",
                "target/${command:raspberry-pi-pico.getTarget}.cfg",
                "-c",
                "adapter speed 5000; program \"${workspaceFolder}/build/zuiki_usb_pio_host.elf\" verify reset exit"
            ],
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/openocd/0.12.0+dev/openocd.exe"
            }
        }
    ]
}
